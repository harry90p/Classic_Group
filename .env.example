# ── PNR sources (Step 5) ──────────────────────────────────────
# Active sources, comma-separated: manual,amadeus,portal
PNR_SOURCES=manual

# Option C — generic portal / consolidator REST API
PORTAL_API_BASE=
PORTAL_API_KEY=

# Option B — Amadeus for Enterprise (Web Services / SOAP). Requires a contract.
AMADEUS_ENDPOINT=
AMADEUS_USERNAME=
AMADEUS_PASSWORD=
AMADEUS_OFFICE_ID=

# Shared secret protecting POST /api/pnrs/sync
SYNC_SECRET=

# Financial data API
FINANCIAL_API_BASE=
FINANCIAL_API_KEY=

# Email (Resend)
RESEND_API_KEY=
REMINDER_FROM_EMAIL=alerts@classicgroupoftravels.com

# WhatsApp Business Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_REMINDER_TEMPLATE=pnr_deadline_reminder

# Reminder windows (hours before expiry)
REMINDER_WINDOWS_HOURS=48,24

# ── Bank payment monitoring (virtual accounts) ────────────────
# Collection-account IBAN stem; the agent's virtual_account_no is appended to it
# to form the IBAN each agent receives funds on. e.g. PK00CLAS0000
BANK_IBAN_PREFIX=
# REST base + key for pulling credits (poll mode). Leave blank to use webhook only.
BANK_API_BASE=
BANK_API_KEY=
# Shared secret for verifying POST /api/payments/webhook (HMAC-SHA256 of the body).
BANK_WEBHOOK_SECRET=
